{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pzmapforge.layer-manifest.v0.1",
  "title": "PZMapForge Layer Manifest v0.1",
  "description": "Multi-layer image pipeline manifest. Declares per-layer image paths, allowed semantic kinds, and merge precedence. Planning artifact only.",
  "type": "object",
  "required": [ "schema", "claim_boundary", "width", "height", "layers", "precedence" ],
  "properties": {
    "schema":         { "type": "string", "const": "pzmapforge.layer-manifest.v0.1" },
    "claim_boundary": { "type": "string", "const": "planning_artifact_only_not_pz_load_tested" },
    "width":          { "type": "integer", "const": 300 },
    "height":         { "type": "integer", "const": 300 },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [ "name", "path", "allowed_kinds" ],
        "properties": {
          "name":          { "type": "string", "minLength": 1 },
          "path":          { "type": "string", "minLength": 1 },
          "allowed_kinds": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "precedence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
