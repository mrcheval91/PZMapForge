{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pzmapforge.map-source.v0.1",
  "title": "PZMapForge Map Source v0.1",
  "description": "Source format for a PZMapForge map description. Source contract only. Not an export format. Not a playable Project Zomboid map.",
  "type": "object",
  "required": [
    "schema",
    "format_version",
    "claim_boundary",
    "map_id",
    "cell_size",
    "cells"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "pzmapforge.map-source.v0.1"
    },
    "format_version": {
      "type": "string",
      "const": "0.1"
    },
    "claim_boundary": {
      "type": "string",
      "const": "map_source_only_not_exported_not_pz_load_tested"
    },
    "map_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_-]+$"
    },
    "cell_size": {
      "type": "integer",
      "minimum": 1
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cell_id", "x", "y", "terrain", "spawn_points", "zones"],
        "additionalProperties": false,
        "properties": {
          "cell_id": {
            "type": "string",
            "minLength": 1
          },
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "terrain": {
            "type": "string",
            "enum": ["grass", "asphalt", "water", "unknown"]
          },
          "spawn_points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "x", "y", "label"],
              "additionalProperties": false,
              "properties": {
                "id":    { "type": "string", "minLength": 1 },
                "x":     { "type": "integer", "minimum": 0 },
                "y":     { "type": "integer", "minimum": 0 },
                "label": { "type": "string" }
              }
            }
          },
          "zones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "kind", "label"],
              "additionalProperties": false,
              "properties": {
                "id":    { "type": "string", "minLength": 1 },
                "kind":  { "type": "string", "minLength": 1 },
                "label": { "type": "string" }
              }
            }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
