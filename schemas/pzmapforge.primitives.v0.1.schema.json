{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pzmapforge.primitives.v0.1",
  "title": "PZMapForge Primitives v0.1",
  "description": "Semantic primitive classification artifact. Planning artifact only, not a PZ load-tested export.",
  "type": "object",
  "required": [
    "schema",
    "claim_boundary",
    "source",
    "width",
    "height",
    "primitive_count",
    "primitives",
    "summary_by_primitive_type"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "pzmapforge.primitives.v0.1"
    },
    "claim_boundary": {
      "type": "string",
      "const": "planning_artifact_only_not_pz_load_tested"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "width":           { "type": "integer", "minimum": 1 },
    "height":          { "type": "integer", "minimum": 1 },
    "primitive_count": { "type": "integer", "minimum": 0 },
    "primitives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "primitive_id", "primitive_type", "source_region_id",
          "kind", "code", "pixel_count", "bounds", "centroid", "planning_role"
        ],
        "properties": {
          "primitive_id":     { "type": "integer", "minimum": 1 },
          "primitive_type":   { "type": "string",  "minLength": 1 },
          "source_region_id": { "type": "integer", "minimum": 1 },
          "kind":             { "type": "string",  "minLength": 1 },
          "code":             { "type": "string",  "minLength": 1, "maxLength": 1 },
          "pixel_count":      { "type": "integer", "minimum": 1 },
          "bounds": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x":      { "type": "integer", "minimum": 0 },
              "y":      { "type": "integer", "minimum": 0 },
              "width":  { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "centroid": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "additionalProperties": false
          },
          "planning_role": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "summary_by_primitive_type": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "primitive_type", "region_count", "total_pixels", "largest_region_pixels"
        ],
        "properties": {
          "primitive_type":        { "type": "string",  "minLength": 1 },
          "region_count":          { "type": "integer", "minimum": 1 },
          "total_pixels":          { "type": "integer", "minimum": 1 },
          "largest_region_pixels": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  }
}
