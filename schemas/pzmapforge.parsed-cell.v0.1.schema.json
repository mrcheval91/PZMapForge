{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pzmapforge.parsed-cell.v0.1",
  "title": "PZMapForge Parsed Cell v0.1",
  "description": "Output artifact from ImageMapForge. Planning artifact only, not a Project Zomboid load-tested export.",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "claim_boundary",
    "source_image",
    "palette",
    "width",
    "height",
    "resized",
    "matching",
    "legend",
    "counts",
    "nearest_drift",
    "rows",
    "outputs"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "pzmapforge.parsed-cell.v0.1"
    },
    "tool": {
      "type": "string"
    },
    "claim_boundary": {
      "type": "string",
      "const": "planning_artifact_only_not_pz_load_tested"
    },
    "source_image": {
      "type": "string",
      "minLength": 1
    },
    "source_image_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "palette": {
      "type": "string",
      "minLength": 1
    },
    "palette_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "resized": {
      "type": "boolean"
    },
    "matching": {
      "type": "object",
      "required": [
        "exact_pixels",
        "nearest_pixels",
        "unique_source_colours",
        "unmapped_exact_colours"
      ],
      "properties": {
        "exact_pixels": {
          "type": "integer",
          "minimum": 0
        },
        "nearest_pixels": {
          "type": "integer",
          "minimum": 0
        },
        "unique_source_colours": {
          "type": "integer",
          "minimum": 1
        },
        "unmapped_exact_colours": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "legend": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "kind", "gid", "rgb"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "gid": {
            "type": "integer",
            "minimum": 1
          },
          "rgb": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0, "maximum": 255 },
            "minItems": 3,
            "maxItems": 3
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "counts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "code", "gid", "pixels"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "code": { "type": "string", "minLength": 1, "maxLength": 1 },
          "gid": { "type": "integer", "minimum": 1 },
          "pixels": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "nearest_drift": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_rgb", "count", "nearest_kind", "nearest_rgb", "distance"],
        "properties": {
          "source_rgb": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 1 },
          "nearest_kind": { "type": "string", "minLength": 1 },
          "nearest_rgb": { "type": "string", "minLength": 1 },
          "distance": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "rows": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "object",
      "required": ["json", "report", "preview", "generated_tileset", "tmx"],
      "properties": {
        "json": { "type": "string" },
        "report": { "type": "string" },
        "preview": { "type": "string" },
        "generated_tileset": { "type": "string" },
        "tmx": { "type": "string" }
      }
    }
  }
}
